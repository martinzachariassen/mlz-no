{
  "name": "mlz-no",
  "version": "1.0.0",
  "private": true,
  "description": "Personal homepage for Martin Zachariassen, served by a hardened Bun + Hono static server.",
  "homepage": "https://mlz.no",
  "author": "Martin Zachariassen <hi@mlz.no>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martinzachariassen/mlz-no.git"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "lint": "biome ci ."
  },
  "dependencies": {
    "hono": "^4.12.31",
    "hono-rate-limiter": "^0.5.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
